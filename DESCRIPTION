Package: itapop
Title: ISTAT Population Data at the Municipal Level
Version: 0.0.0.9000
Authors@R: 
    c(
    person("Giovanni", "Tinervia", , "giovannitinervia9@gmail.com", role = c("aut", "cre")),
    person("Emanuele", "Amodio", , "emanuele.amodio@unipa.it", role = c("aut"))
